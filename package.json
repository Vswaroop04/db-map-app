{
  "name": "draftbit",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:web": "expo export -p web && cp dist/index.html dist/404.html",
    "lint": "prettier --check .",
    "lint:fix": "prettier --write .",
    "deploy": "npm run build:web && wrangler deploy",
    "preview": "npm run build:web && wrangler dev"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.108.1",
    "@types/leaflet": "^1.9.21",
    "babel-preset-expo": "~54.0.10",
    "expo": "~54.0.34",
    "expo-linking": "~8.0.12",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.24",
    "expo-status-bar": "~3.0.9",
    "leaflet": "^1.9.4",
    "nativewind": "^4.2.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-leaflet": "^5.0.0",
    "react-native": "0.81.5",
    "react-native-maps": "1.20.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.6.0",
    "tailwindcss": "^3.4.17",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "~5.9.2",
    "wrangler": "^4.99.0"
  },
  "private": true
}
